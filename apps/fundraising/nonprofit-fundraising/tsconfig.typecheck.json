{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "target": "es2020",
    "lib": ["es2021", "dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.integration-test.ts",
    "src/__tests__/**"
  ],
  "references": []
}
